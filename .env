# ─────────────────────────────────────────────────────────────
# raspi-mc-server — example environment file
#
# This tracked file contains placeholders only. Replace them on the Pi and
# never commit the real operational values.
# ─────────────────────────────────────────────────────────────

# ── Paths ────────────────────────────────────────────────────
# Absolute path to the Minecraft server directory on the Pi.
MC_STORAGE_ROOT=/mnt/minecraft
MC_SERVER_DIR=/mnt/minecraft/live
MC_REQUIRE_STORAGE_MOUNT=true
# Small bot state remains with the repository on the microSD.
MC_STATE_DIR=data

# ── Memory (Pi 4B 4GB) ───────────────────────────────────────
# Heap given to the JVM. 2600M leaves room for the OS + RCON + bot.
MC_MEMORY=2600M
MC_JAR=paper.jar

# ── RCON (remote console) ────────────────────────────────────
# Must match server.properties. RCON is how the bot / CLI send
# commands to the running server. Keep the password private.
RCON_HOST=127.0.0.1
RCON_PORT=25575
RCON_PASSWORD=change-me-to-a-long-random-string

# ── Discord bot ──────────────────────────────────────────────
# Bot token from the Discord Developer Portal.
DISCORD_TOKEN=your-discord-bot-token-here
# Guild (server) ID to register slash commands instantly (dev).
# Accepts several comma-separated IDs (e.g. 111,222) to register in more
# than one server at once. Leave empty to register globally (~1 hour).
DISCORD_GUILD_ID=
# Comma-separated Discord user IDs allowed to run admin commands
# (start/stop, backups, and the raw command channel = "cheats").
# Put ONLY your own ID here to be the sole operator.
ADMIN_USER_IDS=123456789012345678
# Optional: channel ID the bot posts status/announcements to.
STATUS_CHANNEL_ID=

# ── Language / friend portal ─────────────────────────────────
# Discord-facing language for new bot UX: ko or en.
BOT_LANGUAGE=ko
# Friend-safe public commands (/portal, /online). Admin commands stay locked.
PUBLIC_COMMANDS_ENABLED=true
MC_PUBLIC_ADDRESS=play.example.com
MC_PUBLIC_VERSION="Paper Java 26.1.x"
# Base URL the /위키 command links to (issue #71). Override only if you fork
# the repo or serve docs elsewhere; leave blank to use the default repo docs.
MC_WIKI_BASE_URL=

# ── Automatic performance alerts ─────────────────────────────
# Alerts are posted to STATUS_CHANNEL_ID when set.
ALERT_COOLDOWN_MINUTES=30
ALERT_TPS_THRESHOLD=18.0
ALERT_MEMORY_PERCENT=85
ALERT_TEMPERATURE_CELSIUS=80
ALERT_MIN_FREE_GB=15

# ── Idle power-saver (무인 절전, #91) ─────────────────────────
# When nobody is online, the bot stops random block ticks and spawn-chunk
# ticking so the Raspberry Pi runs cooler and draws less power, then restores
# the previous values as soon as a player joins. Only randomTickSpeed and
# spawnChunkRadius are touched (both are performance-only and reversible).
# 아무도 접속하지 않았을 때 랜덤 틱·스폰 청크 틱을 멈춰 Pi의 발열·전력을
# 낮췄다가, 누군가 접속하면 원래대로 되돌립니다.
IDLE_ECO_ENABLED=true
# Minutes the server must stay empty before the saver kicks in.
IDLE_ECO_AFTER_MINUTES=10

# ── Player self-service cooldowns (Discord-account scoped) ─────
# Shared across a player's linked Minecraft accounts; persisted to a file so a
# bot restart does not reset them. 0 disables a cooldown.
TP_COOLDOWN_SECONDS=1800
RESCUE_COOLDOWN_SECONDS=300

# ── systemd unit names (used by the bot to start/stop) ────────
MC_SERVICE_NAME=minecraft.service

# ── Logging ──────────────────────────────────────────────────
LOG_RETENTION_DAYS=14
# Roll the bot log to a new timestamped file once it passes this many bytes
# (in addition to the daily roll). Set 0 to disable the size trigger.
LOG_MAX_BYTES=5242880
