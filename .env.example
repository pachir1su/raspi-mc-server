# ─────────────────────────────────────────────────────────────
# raspi-mc-server — example environment file
#
# Copy this to `.env` and fill in real values. NEVER commit `.env`.
#   cp .env.example .env
#
# The values below are placeholders/examples, not real credentials.
# ─────────────────────────────────────────────────────────────

# ── Paths ────────────────────────────────────────────────────
# Absolute path to the Minecraft server directory on the Pi.
MC_SERVER_DIR=/home/pi/raspi-mc-server/server
# Absolute path where world backups are written.
MC_BACKUP_DIR=/home/pi/raspi-mc-server/backups

# ── Memory (Pi 4B 4GB) ───────────────────────────────────────
# Heap given to the JVM. 2600M leaves room for the OS + RCON + bot.
MC_MEMORY=2600M

# ── RCON (remote console) ────────────────────────────────────
# Must match server.properties. RCON is how the bot / CLI send
# commands to the running server. Keep the password private.
RCON_HOST=127.0.0.1
RCON_PORT=25575
RCON_PASSWORD=change-me-to-a-long-random-string

# ── Discord bot ──────────────────────────────────────────────
# Bot token from the Discord Developer Portal.
DISCORD_TOKEN=your-discord-bot-token-here
# Guild (server) ID to register slash commands instantly (dev).
# Leave empty to register globally (can take up to ~1 hour).
DISCORD_GUILD_ID=
# Comma-separated Discord user IDs allowed to run admin commands
# (start/stop, backups, and the raw command channel = "cheats").
# Put ONLY your own ID here to be the sole operator.
ADMIN_USER_IDS=123456789012345678
# Optional: channel ID the bot posts status/announcements to.
STATUS_CHANNEL_ID=

# ── systemd unit names (used by the bot to start/stop) ────────
MC_SERVICE_NAME=minecraft.service

# ── Logging ──────────────────────────────────────────────────
LOG_RETENTION_DAYS=14
