# Copy to .env, keep it private, and replace every required placeholder.
DISCORD_TOKEN=REPLACE_WITH_DISCORD_BOT_TOKEN
DISCORD_GUILD_ID=
ADMIN_USER_IDS=REPLACE_WITH_YOUR_DISCORD_USER_ID
STATUS_CHANNEL_ID=

# RCON must match server/server.properties (or the HDD server.properties).
RCON_HOST=127.0.0.1
RCON_PORT=25575
RCON_PASSWORD=REPLACE_WITH_RCON_PASSWORD
MC_SERVICE_NAME=minecraft.service

# Keep runtime worlds and large files on the mounted 500 GB HDD.
MC_STORAGE_ROOT=/mnt/minecraft
MC_SERVER_DIR=/mnt/minecraft/live
MC_REQUIRE_STORAGE_MOUNT=true

# Small persistent bot settings stay on the microSD with the repository.
MC_STATE_DIR=data
MC_MEMORY=2600M
MC_JAR=paper.jar
